# Development profile (Mac 8GB friendly)
# Copy to .env and edit values.

# Required
DASHSCOPE_API_KEY=your_dashscope_api_key

# Stable root for source_key (strongly recommended)
# Example: /Users/you/work/docs
RAG_INGEST_ROOT=

# Runtime paths (project-local for easy cleanup)
RAG_CHROMA_PATH=./qwen_rag_data
RAG_LOG_PATH=./rag_process.log
RAG_CACHE_PATH=./file_hash_cache.json

# Ingest tuning (conservative for 8GB RAM)
RAG_RETRY_TIMES=2
RAG_BATCH_SIZE=2
RAG_MAX_FILE_MB=30
RAG_EMBED_BATCH_SIZE=8

# Path normalization
# 0 = abspath; 1/true/yes = realpath (resolve symlinks)
RAG_RESOLVE_SYMLINKS=0

# Optional: xlsx fallback reader limits (when ExcelReader is unavailable)
RAG_XLSX_MAX_SHEETS=20
RAG_XLSX_MAX_ROWS_PER_SHEET=2000
RAG_XLSX_MAX_COLS=50
RAG_XLSX_MAX_CELL_CHARS=300

# Optional: retrieval top-k
RAG_QUERY_TOP_K=5
RAG_CHAT_TOP_K=5

# Optional: source display
RAG_QUERY_SHOW_SOURCES=1
RAG_QUERY_MAX_SOURCE_NODES=5
RAG_QUERY_SOURCE_MAX_CHARS=2000
# 1 = print all source nodes and full text (no truncation)
RAG_QUERY_FULL_OUTPUT=0
