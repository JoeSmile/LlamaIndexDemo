# Production profile (stable defaults)
# Copy to .env in deployment environment and edit values.

# Required
DASHSCOPE_API_KEY=your_dashscope_api_key

# Must be fixed in production to avoid source_key drift
# Example: /data/docs
RAG_INGEST_ROOT=/data/docs

# Runtime paths (use persistent volume)
RAG_CHROMA_PATH=/data/rag/chroma
RAG_LOG_PATH=/data/rag/logs/rag_process.log
RAG_CACHE_PATH=/data/rag/cache/file_hash_cache.json

# Ingest tuning (balanced)
RAG_RETRY_TIMES=3
RAG_BATCH_SIZE=6
RAG_MAX_FILE_MB=100
RAG_EMBED_BATCH_SIZE=10

# Path normalization
# Use 1 when your ingestion paths include symlinks.
RAG_RESOLVE_SYMLINKS=1

# Optional: xlsx fallback reader limits (when ExcelReader is unavailable)
RAG_XLSX_MAX_SHEETS=20
RAG_XLSX_MAX_ROWS_PER_SHEET=2000
RAG_XLSX_MAX_COLS=50
RAG_XLSX_MAX_CELL_CHARS=300

# Optional: retrieval top-k
RAG_QUERY_TOP_K=5
RAG_CHAT_TOP_K=5

# Optional: source display
RAG_QUERY_SHOW_SOURCES=1
RAG_QUERY_MAX_SOURCE_NODES=5
RAG_QUERY_SOURCE_MAX_CHARS=2000
# 1 = print all source nodes and full text (no truncation)
RAG_QUERY_FULL_OUTPUT=0
